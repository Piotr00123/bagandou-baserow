# =====================================================================
# WSPÓLNA KONFIGURACJA BAZ DANYCH I PANELU (WSL2 / RASPBERRY PI)
# =====================================================================
POSTGRES_PASSWORD=wpisz_tutaj_silne_haslo_bazy
UMAMI_APP_SECRET=wpisz_tutaj_losowy_dlugi_ciag_znakow
CUPS_ADMIN_PASSWORD=haslo_administratora_panelu_drukarki

# =====================================================================
# WERSJA DEWELOPERSKA (WSL2 / DOCKER DESKTOP)
# =====================================================================
# Te zmienne uzupełniasz tylko wtedy, gdy uruchamiasz system na Windowsie.
# Domena ngrok zmienia się przy każdym uruchomieniu, chyba że masz płatne konto.
NGROK_AUTHTOKEN=twoj_token_z_panelu_ngrok
NGROK_DOMAIN=twoja-losowa-domena.ngrok-free.app

# =====================================================================
# WERSJA PRODUKCYJNA (RASPBERRY PI 5 - AFRYKA / RCA)
# =====================================================================
# Te zmienne uzupełniasz na malinie w misji.
# Token generujesz w panelu Cloudflare Zero Trust dla danego tunelu.
CLOUDFLARE_TUNNEL_TOKEN=twoj_token_tunelu_cloudflare_dla_rpi
N8N_DOMAIN=kancelaria.twojadomena.pl

# =====================================================================
# ADRESY URL DLA BASEROW
# =====================================================================
# WSL2 lokalnie: http://localhost:8080
# RPi 5 w sieci lokalnej: http://192.168.1.50:8080 (lub podaj domenę z Clouflare)
BASEROW_URL=http://localhost:8080

# =====================================================================
# OPCJONALNA KONFIGURACJA POWIADOMIEŃ EMAIL DLA BASEROW
# =====================================================================
EMAIL_SMTP_HOST=://gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=twoj-email@gmail.com
EMAIL_SMTP_PASSWORD=twoje-haslo-aplikacji
EMAIL_SMTP_USE_TLS=True
FROM_EMAIL=kancelaria@twojadomena.pl
